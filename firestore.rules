rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: employees
    // Fields:
    //   - name: string (required)
    //   - role: string (optional)
    //   - dailyRate: number (optional)
    //   - pixKey: string (optional)
    //   - bankName: string (optional)
    //   - bankAgency: string (optional)
    //   - bankAccount: string (optional)
    //   - ownerId: string (required, immutable)
    //   - createdAt: string (required, immutable)
    //
    // Collection: attendance
    // Fields:
    //   - employeeId: string (required)
    //   - date: string (required)
    //   - type: string (required, enum: D, M, F)
    //   - monthYear: string (required)
    //   - ownerId: string (required, immutable)
    //
    // Collection: userConfigs
    // Fields:
    //   - pin: string (optional, 4-6 digits)
    //   - ownerId: string (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "rodrigovale671@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidEmployee(data) {
      return hasRequiredFields(['name', 'ownerId', 'createdAt']) &&
             hasOnlyAllowedFields(['name', 'role', 'dailyRate', 'pixKey', 'bankName', 'bankAgency', 'bankAccount', 'ownerId', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.ownerId == request.auth.uid &&
             (data.role == null || (data.role is string && data.role.size() < 100)) &&
             (data.dailyRate == null || data.dailyRate is number);
    }

    function isValidAttendance(data) {
      return hasRequiredFields(['employeeId', 'date', 'type', 'monthYear', 'ownerId']) &&
             hasOnlyAllowedFields(['employeeId', 'date', 'type', 'monthYear', 'ownerId']) &&
             data.type in ['D', 'M', 'F'] &&
             data.ownerId == request.auth.uid;
    }

    function isValidUserConfig(data) {
      return hasRequiredFields(['ownerId']) &&
             hasOnlyAllowedFields(['pin', 'ownerId']) &&
             data.ownerId == request.auth.uid &&
             (data.pin == null || (data.pin is string && data.pin.matches('^\\d{4,6}$')));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /employees/{employeeId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidEmployee(request.resource.data);
      allow update: if isDocOwner() && isValidEmployee(request.resource.data) && 
                      request.resource.data.ownerId == resource.data.ownerId &&
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner() || isAdmin();
    }

    match /attendance/{recordId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidAttendance(request.resource.data);
      allow update: if isDocOwner() && isValidAttendance(request.resource.data) &&
                      request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isDocOwner() || isAdmin();
    }

    match /userConfigs/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUserConfig(request.resource.data);
      allow update: if isOwner(userId) && isValidUserConfig(request.resource.data);
      allow delete: if isAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
