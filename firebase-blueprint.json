{
  "entities": {
    "Employee": {
      "title": "Employee",
      "description": "A staff member whose attendance is tracked.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the employee" },
        "role": { "type": "string", "description": "Job title or role" },
        "dailyRate": { "type": "number", "description": "Payment amount per full day" },
        "pixKey": { "type": "string", "description": "PIX key for payments" },
        "bankName": { "type": "string", "description": "Name of the bank" },
        "bankAgency": { "type": "string", "description": "Bank agency number" },
        "bankAccount": { "type": "string", "description": "Bank account number" },
        "ownerId": { "type": "string", "description": "UID of the user who owns this record" },
        "createdAt": { "type": "string", "format": "date-time", "description": "ISO timestamp of creation" }
      },
      "required": ["name", "ownerId", "createdAt"]
    },
    "AttendanceRecord": {
      "title": "AttendanceRecord",
      "description": "A record of an employee's attendance on a specific date.",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string", "description": "ID of the employee" },
        "date": { "type": "string", "format": "date", "description": "Date of attendance (YYYY-MM-DD)" },
        "type": { "type": "string", "enum": ["D", "M", "F"], "description": "D: Diária, M: Meia, F: Falta" },
        "monthYear": { "type": "string", "description": "Month and year (YYYY-MM) for easier querying" },
        "ownerId": { "type": "string", "description": "UID of the user who owns this record" }
      },
      "required": ["employeeId", "date", "type", "monthYear", "ownerId"]
    },
    "UserConfig": {
      "title": "UserConfig",
      "description": "User-specific settings like PIN.",
      "type": "object",
      "properties": {
        "pin": { "type": "string", "description": "4-6 digit security PIN" },
        "ownerId": { "type": "string", "description": "UID of the user" }
      },
      "required": ["ownerId"]
    }
  },
  "firestore": {
    "/employees/{employeeId}": {
      "schema": "Employee",
      "description": "Collection of employees."
    },
    "/attendance/{recordId}": {
      "schema": "AttendanceRecord",
      "description": "Collection of attendance records."
    },
    "/userConfigs/{userId}": {
      "schema": "UserConfig",
      "description": "User settings."
    }
  }
}
